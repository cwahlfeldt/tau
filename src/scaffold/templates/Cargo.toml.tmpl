[package]
name = "tau_app"
version = "{version}"
edition = "2021"
rust-version = "1.77"

[lib]
name = "tau_app"
crate-type = ["staticlib", "cdylib", "rlib"]

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
tauri = { version = "2", features = [] }
tauri-plugin-fs = "2"
tauri-plugin-dialog = "2"
serde = { version = "1", features = ["derive"] }
serde_json = "1"

[target.'cfg(any(target_os = "android", target_os = "ios"))'.dependencies]
tauri-plugin-haptics = "2"

[features]
custom-protocol = ["tauri/custom-protocol"]

# Incremental compilation is useless here: every wrap runs in a fresh tempdir,
# so the incremental cache from a previous run is never reused. Disabling it
# avoids ~100+ MB per build of dead state in the shared CARGO_TARGET_DIR.
[profile.dev]
incremental = false
