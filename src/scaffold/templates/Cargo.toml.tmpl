[package]
name = "tau_app"
version = "{version}"
edition = "2021"
rust-version = "1.77"

[lib]
name = "tau_app"
crate-type = ["staticlib", "cdylib", "rlib"]

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
tauri = { version = "2", features = [] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tauri-plugin-fs = "2"
tauri-plugin-dialog = "2"
tauri-plugin-notification = "2"

# Haptics is mobile-only — leaving it out of desktop builds keeps the dep
# graph (and the shared CARGO_TARGET_DIR) clean.
[target.'cfg(any(target_os = "android", target_os = "ios"))'.dependencies]
tauri-plugin-haptics = "2"

[features]
custom-protocol = ["tauri/custom-protocol"]

# Incremental compilation is useless here: every wrap runs in a fresh tempdir,
# so the incremental cache from a previous run is never reused. Disabling it
# avoids ~100+ MB per build of dead state in the shared CARGO_TARGET_DIR.
[profile.dev]
incremental = false

# Release tuned for shipped binary size. Without these, an unstripped Tauri
# cdylib lands at ~80-100 MB per Android ABI (×4 ABIs in a universal APK);
# stripping + LTO + size-opt cuts that to ~5-15 MB per ABI. Release builds
# are slower as a result, but that cost is only paid on `--release`.
[profile.release]
opt-level = "s"
lto = true
codegen-units = 1
panic = "abort"
strip = true
